# ─── HuggingFace ───
HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# ─── Research API Keys (optional — DuckDuckGo fallback if none set) ───
GNEWS_API_KEY=
SERPER_API_KEY=
NEWSAPI_KEY=

# ─── Model IDs (swap to change LLMs) ───
INGESTOR_MODEL=mistralai/Mistral-7B-Instruct-v0.3
RESEARCH_MODEL=mistralai/Mistral-7B-Instruct-v0.3
RECOMMENDATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ─── LLM Parameters ───
LLM_MAX_NEW_TOKENS=1024
LLM_TEMPERATURE=0.1
